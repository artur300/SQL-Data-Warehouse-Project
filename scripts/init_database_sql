
/*
===============================================
        Create Database and Schemas
===============================================
Script Purpose:
	This script creates a new database named 'DataWarehouse' after checking if it already exists.
	if the database exists, it is dropped and recreated. Additionally, the script sets up three schemes
	within the database:'bronze','silver','gold'.

WARNING:
	Running this script will drop the entire 'DataWarehouse' database if it exists.
	all data in the database will be permanetly deleted. Proceed with caution
	and ensure you have proper backups before running this script


Notes:
--------------------------------------------------------------------------------------
WHAT IS A SCHEMA & WHY DO WE USE IT?

A Schema is like a folder inside the database that groups related tables together.
Full syntax: SCHEMA_NAME.TABLE_NAME (e.g., BRONZE.Orders vs. SILVER.Orders)

WHY WE USE SCHEMAS:
1. Organization: Keeps the database tidy by logical layers (e.g., Bronze, Silver, Gold).
2. Name Reuse: Allows using the same table name at different pipeline stages (BRONZE.Users -> SILVER.Users).
3. Access Control: Makes it easy to manage permissions (e.g., grant BI users access ONLY to Gold).
4. Maintenance: Simplifies back-ups, optimization, and cleanup for specific data layers.
---------------------------------------------------------------------------------------


-- ALTER DATABASE DataWarehouse SET SINGLE_USER WITH ROLLBACK IMMEDIATE:
-- Switches the database to SINGLE_USER mode so only this script can access it.
-- "WITH ROLLBACK IMMEDIATE" aggressively kicks out all connected users right away,
-- rolls back their active transactions, and releases all locks so the database can be dropped cleanly.





*/

USE master;
GO

IF EXISTS
	(
		SELECT 1 FROM sys.databases
		WHERE name='DataWarehouse'
	)
BEGIN 
	ALTER DATABASE DataWarehouse SET SINGLE_USER WITH ROLLBACK IMMEDIATE;
	DROP DATABASE DataWarehouse;
END;

GO



-- Create the DataWarehouse
create database DataWarehouse;
GO

use DataWarehouse;
GO



-- Create the Schemas
create schema bronze;
GO

create schema silver;
GO

create schema gold;
GO






